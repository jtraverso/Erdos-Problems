\section{Preliminaries}\label{sec:prelim}

\begin{lemma}[Telescoping]\label{lem:tele}
Let $G(m):=(m+1)/2^{m-1}$ for $m\ge1$. Then
\[
G(m)-G(m+1)=\frac{m}{2^m}=f(m),
\]
and hence
\begin{equation}\label{eq:tail}
\sum_{k\ge m}f(k)=G(m)=\frac{m+1}{2^{m-1}},
\end{equation}
\begin{equation}\label{eq:block}
\sum_{k=m}^{M}f(k)=\frac{m+1}{2^{m-1}}-\frac{M+2}{2^{M}}.
\end{equation}
In particular $\sum_{k\ge1}f(k)=2$.
\end{lemma}

\begin{proof}
Direct algebra: $G(m)-G(m+1)=\frac{m+1}{2^{m-1}}-\frac{m+2}{2^m}=\frac{2(m+1)-(m+2)}{2^m}=m/2^m$.
\end{proof}

\begin{remark}[Indices must exceed $n$ when $n\ge3$]\label{rem:above}
For $n\ge3$, any solution of $n/2^n=\sum_k f(a_k)$ with distinct $a_k$ satisfies $a_k>n$ for all $k$. Indeed $f$ is strictly decreasing for $k\ge2$, and $f(n-1)=\frac{2n-2}{2^n}>\frac{n}{2^n}$; including any index $\le n-1$ overshoots the target, while $a_k=n$ would force $t=1$. For $n=1,2$ one checks directly that every index in a solution with $t\ge2$ is at least $3$.
\end{remark}

\section{Question 1: infinitely many $n$}\label{sec:q1}

\begin{theorem}[Explicit infinite family]\label{thm:infmany}
For every integer $s\ge3$, set $n=n_s:=2^s-s-1$. Then
\[
\boxed{\ \frac{n_s}{2^{n_s}}=\sum_{k=n_s+1}^{2^s-2}\frac{k}{2^k}\ }
\]
with $t=s-1\ge2$ distinct terms. Hence there are infinitely many $n$ as in Question~(1).
\end{theorem}

\begin{proof}
By \eqref{eq:block} with $m=n+1$ and $M=2^s-2$,
\[
\sum_{k=n+1}^{M}f(k)=\frac{n+2}{2^{n}}-\frac{M+2}{2^{M}}.
\]
The desired identity is therefore equivalent to $M+2=2^{M-n+1}$. With $M=2^s-2$ and $n=2^s-s-1$ we have $M-n+1=s$ and $M+2=2^s$, which holds. The indices $n+1,\ldots,2^s-2$ are distinct and the number of terms is $M-n=s-1\ge2$ for $s\ge3$. Distinct values of $s$ give distinct $n_s$.
\end{proof}

\begin{remark}[First instances]
\[
\frac{4}{2^4}=\frac{5}{2^5}+\frac{6}{2^6},\qquad
\frac{11}{2^{11}}=\frac{12}{2^{12}}+\frac{13}{2^{13}}+\frac{14}{2^{14}},
\]
\[
\frac{26}{2^{26}}=\sum_{k=27}^{30}\frac{k}{2^k},\qquad
\frac{57}{2^{57}}=\sum_{k=58}^{62}\frac{k}{2^k},\ \ldots
\]
\end{remark}

\begin{remark}[A second telescoping family]\label{rem:second}
For every odd $E\ge5$, define
\[
b:=\frac{2^E-5}{3}+1,\qquad a:=b+1-E.
\]
Then $a,b\in\Z_{\ge1}$ and
\[
f(a)+f(b)=\sum_{k=a+1}^{b-1}f(k).
\]
\emph{Proof.} By \eqref{eq:block} the right-hand side equals $(a+2)2^{-a}-(b+1)2^{1-b}$. Equating with $f(a)+f(b)$ and clearing denominators yields $3b+2=2^{b-a+1}$. Since $b-a+1=E$, this is $3b+2=2^E$, which holds by definition of $b$. Odd $E$ ensures $b\in\Z$. First instances: $(a,b)=(6,10),(36,42),(162,170),(672,682)$.
\end{remark}

\section{Question 2: all $n$?}\label{sec:q2}

\subsection{Graph-theoretic reformulation}

\begin{definition}[Corridor digraph]\label{def:gamma}
For a target $n$, a finite representation $S\subset\Z_{\ge1}$ corresponds to a walk in the digraph $\Gamma_n$ whose vertices at \emph{scale} $j\ge n$ are integers $\rho$ with $0\le\rho\le j+2$, and whose edges (when the target lies in the corridor) are
\[
(j,\rho)\longrightarrow(j+1,\,2\rho)\quad\text{(exclude $j+1$)},\qquad
(j,\rho)\longrightarrow(j+1,\,2\rho-(j+1))\quad\text{(include $j+1$)}.
\]
\end{definition}

\begin{proposition}[Exact equivalence]\label{prop:graph}
Fix $n\ge1$. There exist mutually distinct integers $a_1,\ldots,a_t\ge1$ with $t\ge1$ and
\[
\frac{n}{2^n}=\sum_{k=1}^{t}f(a_k)
\]
if and only if the vertex $(n,n)$ of $\Gamma_n$ can reach some vertex $(J,0)$ with $J\ge n$. In that case one may take $S=\{k\in(n,J]:\ \text{the edge at scale $k-1$ is an Include edge}\}$.
\end{proposition}

\begin{proof}
Define the remainder at scale $j\ge n$ by
\[
\rho_j:=2^j\Big(\frac{n}{2^n}-\sum_{k\in S,\,k\le j}f(k)\Big),
\]
with $S$ the index set being built. Then $\rho_n=n$, each $\rho_j\in\Z$, and the transition rule is
\[
\rho_{j+1}=2\rho_j-(j+1)\,\mathbf 1[\,j+1\in S\,],
\]
exactly the two edge types above. By \eqref{eq:tail}, the total tail after scale $j$ is $2^{-j}(j+2)$, so any finite representation stays in $0\le\rho_j\le j+2$. Conversely, reaching $(J,0)$ means the partial sum equals $n/2^n$ exactly with all chosen indices $\le J$. Distinctness of indices is built into using each scale at most once.
\end{proof}

\begin{remark}[Branching is rare]
Both edges leave $(j,\rho)$ only when $2\rho\in\{j+1,j+2,j+3\}$, a window of width $3$ inside a corridor of width $j+3$. The walk is therefore almost deterministic; hitting $\rho=0$ is a delicate exact problem.
\end{remark}

