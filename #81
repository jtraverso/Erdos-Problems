\section{Lower Bound: the Extremal Family}
\label{sec:lower}

\begin{definition}
For $m\ge 1$, let $G_m=\Sp(K_m,I_{2m})$: vertex set $U\cup W$ with
$|U|=m$, $|W|=2m$; $U$ induces $K_m$; $W$ is independent; all $2m^2$
edges of $U\times W$ are present.
\end{definition}

\begin{lemma}
\label{lem:split-chordal}
$G_m$ is chordal, has $|E(G_m)|=(5m^2-m)/2$, and every clique is either
\emph{Type~A} (contained in $U$) or \emph{Type~B} ($\{w\}\cup Q$, $w\in W$,
$Q\subseteq U$).
\end{lemma}

\begin{proof}
Any induced cycle of length $k\ge 4$ would alternate between $W$ and $U$
(since $W$ is independent), but any two $U$-vertices on the cycle are
adjacent (as $U=K_m$), giving a chord --- contradiction.  The edge count
and clique classification follow immediately from the definition.
\end{proof}

\begin{theorem}[Lower bound via LP duality]
\label{thm:lb}
$\cp(G_m)\ge(3m^2+m)/2$.
\end{theorem}

\begin{proof}
Set $y_e=+1$ for $UW$-edges and $y_e=-1$ for $UU$-edges in~\eqref{eq:D}.
The dual objective equals $2m^2-\binom{m}{2}=(3m^2+m)/2$.
Dual feasibility: for Type~A cliques, $\sum y_e=-\binom{r}{2}\le 0\le 1$;
for Type~B cliques with $|Q|=s$, $\sum y_e=s-\binom{s}{2}=s(3-s)/2$, which
equals $1$ at $s\in\{1,2\}$ and is $\le 0$ for $s\ge 3$.  Weak duality gives
the result.
\end{proof}

\begin{construction}[Optimal CEP of $G_m$]
\label{con:cep}
Fix a $1$-factorisation $M_1,\dots,M_r$ of $K_m$ (\cref{lem:1fac}).
Assign $M_k$ to $w_k\in W$; for each $\{u_a,u_b\}\in M_k$ add triangle
$\{w_k,u_a,u_b\}$.  Cover each remaining $UW$-edge by a $2$-clique.
\end{construction}

\begin{lemma}[$1$-factorisation]
\label{lem:1fac}
For $m\ge 2$, $E(K_m)$ can be partitioned into $m-1$ perfect matchings
(even $m$) or $m$ near-perfect matchings (odd $m$).
\end{lemma}

\begin{proof}
Classical: for even $m$, use the round-robin construction; for odd $m$,
add a dummy vertex to form $K_{m+1}$ and project~\cite{Diestel}.
\end{proof}

\begin{theorem}[Exact value]
\label{thm:exact}
$\cp(G_m)=(3m^2+m)/2=n^2/6+n/6$ for $n=3m$.
\end{theorem}

\begin{proof}
\cref{thm:lb} gives the lower bound for all $m\ge 1$.

For the upper bound: if $m=1$, then $G_1=\Sp(K_1,I_2)$ is a two-edge star
(one centre vertex adjacent to two leaves, no other edges), and any CEP
must use two edge-cliques, so $\cp(G_1)=2=(3\cdot1+1)/2$.  Assume $m\ge 2$.
\cref{con:cep} gives $\binom{m}{2}+(m^2+m)=(3m^2+m)/2$ cliques (verified by
direct count), proving the upper bound.
The formula in $n$ follows from $m=n/3$.
\end{proof}

\begin{corollary}
\label{cor:tight}
Any asymptotic universal bound of the form
  \[
    \cp(G)\;\le\;cn^2+O(n)
  \]
  for chordal graphs must have $c\ge 1/6$.
\end{corollary}

