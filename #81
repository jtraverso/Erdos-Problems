\section{Preliminaries}
\label{sec:prelim}

\begin{definition}[Notation]
Write $\omega(G)$ for the clique number of $G$.  For a set $K\subseteq V(G)$,
write $G-E(K)$ for the graph obtained by deleting all edges within $K$.
\end{definition}

\begin{theorem}[\cite{FulkersonGross,Rose}]
\label{thm:peo}
$G$ is chordal if and only if it admits a PEO; equivalently, every induced
subgraph has a simplicial vertex (a vertex whose neighbourhood is a clique).
\end{theorem}

\begin{definition}[CEP LP and dual]
The fractional CEP LP over all cliques $\mathcal{K}(G)$ and its dual are:
\begin{align}
  &\min\;\textstyle\sum_K x_K
   \;\text{ s.t. }\;\textstyle\sum_{K\ni e}x_K=1\;\forall e,\;x_K\ge 0,
   \tag{P}\label{eq:P}\\
  &\max\;\textstyle\sum_e y_e
   \;\text{ s.t. }\;\textstyle\sum_{e\in E(K)}y_e\le 1\;\forall K,\;y_e\in\R.
   \tag{D}\label{eq:D}
\end{align}
Since \eqref{eq:P} uses equalities, $y_e$ is unrestricted in~\eqref{eq:D}.
Weak duality gives $\cp(G)\ge\operatorname{opt}(\text{D})$.
\end{definition}

