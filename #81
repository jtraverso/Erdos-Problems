\section{Status of the Weak Clique-Drop Hypothesis}
\label{sec:cdh-status}

\subsection{wCDH is not universal among chordal graphs}

Before seeking cases where wCDH holds, we establish that it fails for
the graphs of highest interest --- the very family that witnesses the $n^2/6$
lower bound.

\begin{proposition}[wCDH fails for $G_m$, $m\ge 3$]
\label{prop:cdh-fails}
For $m\ge 3$, the graph $G_m=\Sp(K_m,I_{2m})$ does not satisfy wCDH\@:
for \emph{every} maximum clique $K$ of $G_m$,
\[
  \omega(G_m-E(K))\;=\;2\;<\;m\;=\;\omega(G_m)-1.
\]
\end{proposition}

\begin{proof}
The maximum cliques of $G_m$ have size $\omega(G_m)=m+1$ and are of the form
$K=\{w\}\cup U$ for $w\in W$, $U=K_m$.  Fix any such $K$ and let $G':=G_m-E(K)$.

Removing $E(K)$ deletes all $\binom{m}{2}$ within-$U$ edges and all $m$
edges from $w$ to $U$.  In $G'$: $U$ is an independent set (all within-$U$
edges removed); every other $w'\in W\setminus\{w\}$ remains adjacent to all
of $U$; and $w$ has no neighbours.

A clique $C$ in $G'$ can contain at most one vertex of $U$ (since $U$ is
independent in $G'$), so $|C|\le 2$.  Since any $w'\in W\setminus\{w\}$ and
any $u\in U$ are adjacent in $G'$, the pair $\{w',u\}$ is a clique of size~$2$.
Hence $\omega(G')=2$.

wCDH requires $\omega(G')\ge\omega(G_m)-1=m$.  Since $2<m$ for $m\ge 3$, wCDH fails.
\end{proof}

\begin{remark}
\label{rem:cdh-splits}
\cref{prop:cdh-fails} shows wCDH fails for the very family that achieves
$\cp=n^2/6$.  The conditional proof of \cref{thm:conditional} therefore does
\emph{not} apply to these graphs.  Closing the open problem requires an
argument that handles the wCDH-failing case --- precisely the case where the
clique number drops by $\omega-2$ or more upon a single compression.
\end{remark}

\subsection{Cases where wCDH holds}

\begin{proposition}[wCDH holds for non-trivial trees]
\label{prop:cdh-trees}
Every tree $G$ with at least two vertices satisfies wCDH\@: $\omega(G)=2$,
every maximum clique is a single edge $K=\{u,v\}$, and $G-E(K)=G-\{uv\}$
has $\omega(G-\{uv\})\ge 1=\omega(G)-1$.
\end{proposition}

\begin{remark}[Small cases of wCDH]
For $\omega(G)=3$, wCDH requires that \emph{some} maximum triangle $K$
satisfies $\omega(G-E(K))\ge 2$.  This holds whenever $G-E(K)$ retains
at least one edge for some choice of triangle.  It fails for $G=K_3$
(the only triangle, once removed, leaves no edges), confirming that wCDH
is not a universal property even for small $\omega$.
\end{remark}

\subsection{Status of wCDH}

\begin{warningbox}
\noindent\textbf{wCDH is not universal among chordal graphs.}
As \cref{prop:cdh-fails} shows, $G_m$ does not satisfy wCDH for $m\ge 3$:
every maximum clique removal drops the clique number from $m+1$ to $2$.

The conditional proof of \cref{thm:conditional} therefore applies only to
the subclass of chordal graphs satisfying wCDH\@.  It identifies a precise
sufficient condition for the $n^2/6$ bound, but since the extremal family
fails wCDH, a different argument is needed for the full problem.
\end{warningbox}

\begin{remark}[What the two-step argument proves unconditionally]
For any chordal graph $G$ satisfying wCDH (i.e., there exists a maximum
clique $K$ with $\omega(G-E(K))\ge\omega(G)-1$), \cref{thm:conditional}
gives $\cp(G)\le n^2/6+O(n)$.  The open case is precisely those chordal
graphs where every maximum clique removal drops the clique number by at
least $2$, exemplified by the split graphs $G_m$.
\end{remark}

