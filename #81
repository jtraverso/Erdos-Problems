\title{\textbf{Partial Results on Clique Edge-Partitions of Chordal Graphs}\\[6pt]
\large An $n^2/4+O(n)$ Upper Bound, a Sharp $n^2/6$ Lower Bound,\\
and a Conditional $n^2/6$ Theorem for a Subclass}
\author{Jamal Agbanwa}
\date{\today}
\maketitle\thispagestyle{empty}

\begin{abstract}
Let $G$ be a chordal graph on $n$ vertices and let $\cp(G)$ denote the
minimum number of cliques in a partition of $E(G)$.  We establish three
results.
\begin{enumerate}[label=(\arabic*),leftmargin=2em]
  \item \textbf{(Proved.)} $\cp(G)\le\lfloor(n-1)^2/4\rfloor+1=n^2/4+O(n)$
    unconditionally, via the perfect elimination ordering and a single
    maximum-clique compression.
  \item \textbf{(Proved.)} The split graph $G_m=\Sp(K_m,I_{2m})$ on
    $n=3m$ vertices is chordal and satisfies
    \[
      \cp(G_m)=\frac{3m^2+m}{2}=\frac{n^2}{6}+\frac{n}{6}.
    \]
    This is proved via LP duality and an explicit $1$-factorisation
    construction, and shows the coefficient $1/6$ cannot be improved.
  \item \textbf{(Conditional.)} If $G$ satisfies the \emph{weak Clique-Drop
    Hypothesis} (wCDH) --- namely, if there exists a maximum clique $K$
    such that
    \[
      \omega(G-E(K))\;\ge\;\omega(G)-1,
    \]
    --- then $\cp(G)\le n^2/6+O(n)$.  We prove this conditional result in
    full.  The hypothesis is not universal among chordal graphs: it fails
    for the split graphs $G_m$, so the theorem applies only to a subclass.
\end{enumerate}
\end{abstract}

\begin{provedbox}
\noindent\textbf{What is unconditionally established.}
\begin{itemize}[nosep]
  \item $\cp(G_m)=n^2/6+n/6$ for $n=3m$:\quad proved (\cref{thm:exact}).
  \item $\cp(G)\le n^2/4+O(n)$ for all chordal $G$:\quad proved (\cref{thm:upper-n4}).
  \item $\cp(G)\le n^2/6+O(n)$ for all chordal $G$ satisfying wCDH:\quad proved
    (\cref{thm:conditional}).  wCDH is not universal among chordal graphs
    (\cref{prop:cdh-fails}), so this applies only to a subclass.
\end{itemize}
\end{provedbox}

