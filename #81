\section{Unconditional Upper Bound: $n^2/4+O(n)$}
\label{sec:upper}

\begin{lemma}[Edge bound from PEO]
\label{lem:edge-bound}
If $G$ is chordal on $n$ vertices with clique number $\omega$, then
$|E(G)|\le(\omega-1)n-\binom{\omega}{2}$.
\end{lemma}

\begin{proof}
Let $v_1,\dots,v_n$ be a PEO.  Since $\Nplus(v_i)$ is a clique of size
$d_i^+$, we have $d_i^+\le\omega-1$.  Also $d_i^+\le n-i$.  Thus
$d_i^+\le\min(\omega-1,n-i)$, and summing with $k:=\omega-1$:
\[
  |E(G)|=\sum_i d_i^+\le\sum_{j=0}^{n-1}\min(k,j)
  =\frac{k(k+1)}{2}+(n-1-k)k=kn-\frac{k(k+1)}{2}=(\omega-1)n-\binom{\omega}{2}.
  \qquad\square
\]
\end{proof}

\begin{lemma}[Single-clique compression]
\label{lem:compress1}
For any graph $G$:
$\cp(G)\le 1+|E(G)|-\binom{\omega(G)}{2}$.
\end{lemma}

\begin{proof}
Use one maximum clique $K$ (covering $\binom{\omega}{2}$ edges) plus one
edge-clique for every remaining edge.  Remaining edges have at most one
endpoint in $K$ (else both endpoints would be in $K$ and their edge already
covered), so no edge-clique conflicts with $K$.
\end{proof}

\begin{theorem}[Unconditional upper bound]
\label{thm:upper-n4}
For every chordal graph $G$ on $n$ vertices,
$\cp(G)\le\lfloor(n-1)^2/4\rfloor+1\le n^2/4+O(n)$.
\end{theorem}

\begin{proof}
Let $\omega=\omega(G)$.  Combining \cref{lem:edge-bound,lem:compress1}:
\[
  \cp(G)\le 1+(\omega-1)n-2\binom{\omega}{2}
  =1+(\omega-1)(n-\omega).
\]
Setting $x=\omega-1$, we maximise $x(n-1-x)$ over $0\le x\le n-1$.  This
concave quadratic peaks at $x=(n-1)/2$ with maximum $\lfloor(n-1)^2/4\rfloor$.
\end{proof}

