\section{Summary and Open Problem}
\label{sec:summary}

\begin{theorem}[Complete unconditional knowledge]
\label{thm:final}
Let $f(n):=\max\{\cp(G):G\text{ chordal on }n\text{ vertices}\}$.  Then:
\[
  \frac{n^2}{6}-O(n)\;\le\;f(n)\;\le\;\frac{n^2}{4}+O(n).
\]
More precisely, $f(3m)\ge\dfrac{(3m)^2}{6}+\dfrac{3m}{6}=\dfrac{3m^2+m}{2}$
for every $m\ge 1$, witnessed by $G_m=\Sp(K_m,I_{2m})$.
\end{theorem}

\begin{openproblem}
\label{op:main}
Is $f(n)=n^2/6+O(n)$?
\end{openproblem}

\begin{remark}[The remaining gap]
The two-step compression of \cref{sec:conditional} identifies wCDH as a
sufficient condition for the $n^2/6$ bound.  Since wCDH fails for the
extremal family $G_m$, the full open problem requires an argument that
works precisely for wCDH-failing graphs: those where removing a maximum
clique drops the clique number by $2$ or more.  It is this harder case
--- exemplified by the split graphs --- that remains unresolved.
\end{remark}

