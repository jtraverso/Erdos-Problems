\section{A Conditional Proof of $n^2/6+O(n)$}
\label{sec:conditional}

\subsection{The weak Clique-Drop Hypothesis}

For graphs satisfying the following structural property, the gap between
$n^2/4$ and $n^2/6$ can be bridged:

\begin{definition}[Weak Clique-Drop Hypothesis, \textbf{wCDH}]
\label{def:cdh}
A chordal graph $G$ with clique number $\omega$ satisfies \emph{wCDH} if
there \emph{exists} a maximum clique $K\subseteq V(G)$ such that
\[
  \omega(G-E(K))\;\ge\;\omega-1.
\]
\end{definition}

\begin{remark}
The stronger condition that \emph{every} maximum clique satisfies the drop
bound is called CDH (Clique-Drop Hypothesis).  wCDH suffices for the proof
below.  Since our result only needs one such clique, we state it in this
weaker form.
\end{remark}

\subsection{The two-step compression}

\begin{lemma}[Two-step compression]
\label{lem:two-step}
Let $G$ be any graph with $|E(G)|\le M$, $\omega(G)=\omega$, and suppose
$G':=G-E(K)$ satisfies $\omega(G')\ge\omega-1$ for some maximum clique
$K\subseteq V(G)$.  Then
\[
  \cp(G)\;\le\;2\;+\;M\;-\;\binom{\omega}{2}\;-\;\binom{\omega-1}{2}.
\]
\end{lemma}

\begin{proof}
Use $K$ (one CEP element) to cover $\binom{\omega}{2}$ edges; this leaves
$G'$ with $|E(G')|\le M-\binom{\omega}{2}$ edges.  By \cref{lem:compress1}
applied to $G'$ (which has clique number $\ge\omega-1$ by assumption):
\[
  \cp(G')\;\le\;1+|E(G')|-\binom{\omega(G')}{2}
  \;\le\;1+\!\left(M-\binom{\omega}{2}\right)-\binom{\omega-1}{2}.
\]
Hence $\cp(G)\le 1+\cp(G')\le 2+M-\binom{\omega}{2}-\binom{\omega-1}{2}$.
\end{proof}

\subsection{The conditional $n^2/6$ theorem}

\begin{theorem}[Conditional upper bound]
\label{thm:conditional}
Let $G$ be a chordal graph on $n$ vertices satisfying \emph{wCDH}.  Then
\[
  \cp(G)\;\le\;\frac{n^2}{6}+O(n).
\]
\end{theorem}

\begin{proof}
Let $\omega=\omega(G)$ and $M=|E(G)|$.  By wCDH there exists a maximum
clique $K$ such that $\omega(G-E(K))\ge\omega-1$, so $G$ satisfies the
hypothesis of \cref{lem:two-step} with this choice of $K$:
\[
  \cp(G)\;\le\;2+M-\binom{\omega}{2}-\binom{\omega-1}{2}.
\]
Now $\binom{\omega}{2}+\binom{\omega-1}{2}=\frac{\omega(\omega-1)}{2}+\frac{(\omega-1)(\omega-2)}{2}
=(\omega-1)^2$.  Hence:
\begin{equation}
  \cp(G)\;\le\;2+M-(\omega-1)^2.
  \label{eq:two-step-bound}
\end{equation}
By \cref{lem:edge-bound}, $M\le(\omega-1)n-\binom{\omega}{2}$.
Substituting:
\begin{align*}
  \cp(G)
  &\le 2+(\omega-1)n-\binom{\omega}{2}-(\omega-1)^2\\
  &=2+(\omega-1)n-\frac{\omega(\omega-1)}{2}-(\omega-1)^2\\
  &=2+(\omega-1)\!\left[n-\frac{\omega}{2}-(\omega-1)\right]\\
  &=2+(\omega-1)\!\left[n+1-\frac{3\omega}{2}\right].
\end{align*}
Set $x:=\omega-1\ge 0$.  Then:
\[
  \cp(G)\;\le\;2+x\!\left(n+1-\tfrac{3(x+1)}{2}\right)
  =2+x\!\left(n-\tfrac{1}{2}-\tfrac{3x}{2}\right).
\]
The function $h(x)=x(n-\tfrac{1}{2}-\tfrac{3x}{2})$ is a concave quadratic
in $x$, maximised at $x^*=(n-\tfrac{1}{2})/3=(2n-1)/6$.  Its maximum value is:
\[
  h(x^*)
  =\frac{2n-1}{6}\cdot\frac{2n-1}{4}
  =\frac{(2n-1)^2}{24}
  =\frac{4n^2-4n+1}{24}.
\]
Therefore:
\[
  \cp(G)\;\le\;2+\frac{(2n-1)^2}{24}
  =\frac{(2n-1)^2}{24}+2
  =\frac{4n^2-4n+1}{24}+2
  =\frac{n^2}{6}-\frac{n}{6}+\frac{1}{24}+2
  =\frac{n^2}{6}+O(n).\qquad\square
\]
\end{proof}

\begin{remark}[Precision of the bound]
The exact bound from the proof is $\cp(G)\le(4n^2-4n+1)/24+2=(2n-1)^2/24+2$.
For large $n$ this is $n^2/6+O(n)$.  Combined with \cref{cor:tight}, wCDH
holding universally would imply $f(n)=n^2/6+O(n)$, settling the problem
completely.  Since wCDH is not universal, however, this remains open.
\end{remark}

