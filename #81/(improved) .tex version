\section{A conditional $n^2/6$ theorem}
\label{sec:conditional}

\subsection{The weak Clique-Drop Hypothesis}

\begin{definition}[wCDH]
\label{def:wcdh}
A chordal graph $G$ with $\omega=\omega(G)$ satisfies the
\emph{weak Clique-Drop Hypothesis} (wCDH) if there exists a maximum
clique $K\subseteq V(G)$ such that
\[
  \omega(G-E(K))\;\ge\;\omega-1.
\]
\end{definition}

For graphs satisfying wCDH, the gap between $n^2/4$ and $n^2/6$ can be
bridged:

\begin{lemma}[Two-step compression]
\label{lem:two-step}
Let $G$ be any graph with $|E(G)|\le M$ and $\omega(G)=\omega$.  Suppose
$G-E(K)$ satisfies $\omega(G-E(K))\ge\omega-1$ for some maximum clique
$K$.  Then
\[
  \cp(G)\;\le\;2+M-\tbinom{\omega}{2}-\tbinom{\omega-1}{2}.
\]
\end{lemma}

\begin{proof}
Use $K$ (one CEP element) covering $\binom{\omega}{2}$ edges; the
remainder $G':=G-E(K)$ has $|E(G')|\le M-\binom{\omega}{2}$ and
$\omega(G')\ge\omega-1$.  By \cref{lem:compress1} applied to $G'$:
\[
  \cp(G')\le 1+\bigl(M-\tbinom{\omega}{2}\bigr)-\tbinom{\omega-1}{2}.
\]
Hence $\cp(G)\le 1+\cp(G')\le 2+M-\binom{\omega}{2}-\binom{\omega-1}{2}$.
\end{proof}

\subsection{The conditional theorem}

\begin{theorem}[Conditional $n^2/6$ bound]
\label{thm:conditional}
Let $G$ be a chordal graph on $n$ vertices satisfying wCDH.  Then
\[
  \cp(G)\;\le\;\frac{(2n-1)^2}{24}+2\;=\;\frac{n^2}{6}+O(n).
\]
\end{theorem}

\begin{proof}
Let $\omega=\omega(G)$ and $M=|E(G)|$.  By wCDH, \cref{lem:two-step} applies:
\[
  \cp(G)\;\le\;2+M-\tbinom{\omega}{2}-\tbinom{\omega-1}{2}
  =2+M-(\omega-1)^2,
\]
using $\binom{\omega}{2}+\binom{\omega-1}{2}=(\omega-1)^2$.  By
\cref{lem:edge-bound}, $M\le(\omega-1)n-\binom{\omega}{2}$.  Substituting
and setting $x:=\omega-1$:
\begin{align*}
  \cp(G)&\le 2+(\omega-1)n-\tbinom{\omega}{2}-(\omega-1)^2
  =2+(\omega-1)\!\left[n+1-\tfrac{3\omega}{2}\right]\\
  &=2+x\!\left(n-\tfrac{1}{2}-\tfrac{3x}{2}\right).
\end{align*}
The function $h(x)=x(n-\frac{1}{2}-\frac{3x}{2})$ is a concave quadratic
maximised at $x^*=(2n-1)/6$, with $h(x^*)=(2n-1)^2/24$.  Hence
$\cp(G)\le 2+(2n-1)^2/24=n^2/6+O(n)$.
\end{proof}

\begin{remark}[Lean verification]
The proof of \cref{thm:conditional} has been independently formalized in
the proof assistant Lean~4 by W.~van Doorn~\cite{Wouter2026}.
\end{remark}

