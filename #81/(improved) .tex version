\section{The \EOZ{} lower-bound family and its exact clique-partition number}
\label{sec:lower}

\EOZ{} \cite{EOZ1993} exhibit a split graph achieving $n^2/6$.  We identify
this as $G_m=\Sp(K_m,I_{2m})$ and determine $\cp(G_m)$ exactly.

\begin{definition}
For $m\ge 1$, let $G_m=\Sp(K_m,I_{2m})$: vertex set $U\cup W$,
$|U|=m$, $|W|=2m$, $U$ induces $K_m$, $W$ is independent, all
$2m^2$ edges of $U\times W$ present.
\end{definition}

\begin{lemma}
\label{lem:split-chordal}
$G_m$ is chordal with $|E(G_m)|=(5m^2-m)/2$.  Every clique is
\emph{Type~A} ($\subseteq U$) or \emph{Type~B} ($\{w\}\cup Q$,
$w\in W$, $Q\subseteq U$).
\end{lemma}

\begin{proof}
Let $C$ be an induced cycle in $G_m$ of length at least~$4$.  Since $W$ is
independent, no two vertices of $W$ are consecutive on $C$.  Hence $C$
contains at least two vertices of $U$.

If $C$ contains two non-consecutive vertices of $U$, then these two vertices
are adjacent (since $U$ induces a clique $K_m$), giving a chord of $C$, a
contradiction.  Thus every pair of $U$-vertices on $C$ must be consecutive.

An induced cycle of length at least~$4$ cannot have exactly one vertex of $U$
(then two $W$-vertices would be consecutive, impossible).  If it has exactly
two $U$-vertices and they are non-consecutive, we get a chord; if they are
consecutive, the remaining path between them passes entirely through $W$, forcing
two consecutive $W$-vertices --- again impossible.  If it has at least three
$U$-vertices, some two are non-consecutive, giving a chord.  In every case
we reach a contradiction, so no induced cycle of length at least~$4$ exists
and $G_m$ is chordal.

The edge count $|E(G_m)|=(5m^2-m)/2$ and the clique classification follow
immediately from the definition.
\end{proof}

\subsection{Lower bound via LP duality}

\begin{theorem}[Exact lower bound]
\label{thm:lb}
$\cp(G_m)\ge(3m^2+m)/2$.
\end{theorem}

\begin{proof}
We exhibit a feasible dual solution to~\eqref{eq:D} with objective
$(3m^2+m)/2$.  Set
\[
  y_e:=\begin{cases}+1&e\text{ is a }UW\text{-edge,}\\
  -1&e\text{ is a }UU\text{-edge.}\end{cases}
\]
\textbf{Objective:} $\sum_e y_e=2m^2\cdot(+1)+\binom{m}{2}\cdot(-1)
=2m^2-\tfrac{m(m-1)}{2}=\tfrac{3m^2+m}{2}$.

\textbf{Feasibility.}  For Type~A cliques of size $r$:
$\sum y_e=-\binom{r}{2}\le 0\le 1$.  For Type~B cliques with $|Q|=s$:
$\sum y_e=s-\binom{s}{2}=\tfrac{s(3-s)}{2}$, which equals $1$ for
$s\in\{1,2\}$ and is $\le 0$ for $s\ge 3$.

By weak LP duality, $\cp(G_m)\ge\tfrac{3m^2+m}{2}$.
\end{proof}

\subsection{Upper bound via $1$-factorisation}

\begin{lemma}[$1$-factorisation~{\cite{Diestel}}]
\label{lem:1fac}
For $m\ge 2$, $E(K_m)$ decomposes into $m-1$ perfect matchings (even $m$)
or $m$ near-perfect matchings (odd $m$).
\end{lemma}

\begin{construction}[Optimal CEP of $G_m$]
\label{con:cep}
Fix a $1$-factorisation $M_1,\dots,M_r$ of $K_m$.  Assign $M_k$ to
$w_k\in W$; for each $\{u_a,u_b\}\in M_k$, add the triangle
$\{w_k,u_a,u_b\}$.  Cover each remaining $UW$-edge by a $2$-clique.
\end{construction}

\begin{proposition}
\label{prop:upper-split}
Construction~\ref{con:cep} is a valid CEP of $G_m$ of size $(3m^2+m)/2$.
\end{proposition}

\begin{proof}
Each $UU$-edge belongs to exactly one matching $M_k$ and hence one
triangle; covered $UW$-edges are in their triangle; remaining $UW$-edges
each get a $2$-clique.  No edge is double-counted.  Size:
$\binom{m}{2}+(m^2+m)=(3m^2+m)/2$.
\end{proof}

\begin{theorem}[Exact value]
\label{thm:exact}
$\cp(G_m)=\dfrac{3m^2+m}{2}=\dfrac{n^2}{6}+\dfrac{n}{6}$ for $n=3m$,
for every $m\ge 1$.
\end{theorem}

\begin{proof}
For $m=1$: $G_1=\Sp(K_1,I_2)$ is a two-edge star with $\cp(G_1)=2=(3\cdot1+1)/2$.
For $m\ge 2$: lower bound from \cref{thm:lb}, upper bound from
\cref{prop:upper-split}.  The formula in $n$ uses $m=n/3$.
\end{proof}

\begin{corollary}
\label{cor:tight}
Any asymptotic bound $\cp(G)\le cn^2+O(n)$ for chordal graphs must have
$c\ge 1/6$.  In particular, $f(3m)\ge(3m)^2/6+(3m)/6$.
\end{corollary}

