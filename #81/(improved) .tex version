\section{Summary}
\label{sec:summary}

\begin{theorem}[What is known]
\label{thm:final}
Let $f(n):=\max\{\cp(G):G\text{ chordal on }n\text{ vertices}\}$.  Then:
\[
  \frac{n^2}{6}-O(n)\;\le\;f(n)\;\le\;\frac{n^2}{4}+O(n),
\]
and more precisely $f(3m)\ge(3m)^2/6+(3m)/6$ for all $m\ge 1$.
\EOZ{}~\cite{EOZ1993} prove the stronger upper bound $(1-c)n^2/4$.
\end{theorem}

\begin{openproblem}[\EOZ{} \cite{EOZ1993}]
\label{op:main}
Is $f(n)=n^2/6+O(n)$?
\end{openproblem}

\begin{remark}[What wCDH reduces the problem to]
\cref{thm:conditional} settles the open problem for wCDH-satisfying chordal
graphs.  The remaining open case is graphs where every maximum clique
removal drops the clique number by at least $2$ --- precisely the class
containing $G_m$ (\cref{prop:wcdh-fails}).
\end{remark}

