\section{Status of wCDH}
\label{sec:wcdh}

\subsection{wCDH is not universal among chordal graphs}

\begin{proposition}[wCDH fails for $G_m$, $m\ge 3$]
\label{prop:wcdh-fails}
For $m\ge 3$, $G_m$ does not satisfy wCDH: for every maximum clique $K$,
\[
  \omega(G_m-E(K))=2<m=\omega(G_m)-1.
\]
\end{proposition}

\begin{proof}
Every maximum clique of $G_m$ has the form $K=\{w\}\cup U$ for $w\in W$.
Removing $E(K)$ deletes all within-$U$ edges and all edges from $w$ to $U$.
In $G':=G_m-E(K)$: $U$ is independent, $w$ is isolated, and each
$w'\in W\setminus\{w\}$ is still adjacent to all of $U$.  Any clique in
$G'$ has at most one vertex from $U$ (since $U$ is independent), so
$\omega(G')=2$.  Since $2<m$ for $m\ge 3$, wCDH fails.
\end{proof}

\begin{remark}
\cref{prop:wcdh-fails} shows that the open case --- graphs where every
maximum clique removal drops $\omega$ by at least $2$ --- is precisely
the class containing the \EOZ{} lower-bound family.  The wCDH-failing class
is therefore not merely a technicality; it is where the hardest instances live.
\end{remark}

\subsection{wCDH holds for trees}

\begin{proposition}
Every tree with at least two vertices satisfies wCDH\@: $\omega=2$, and
removing any edge leaves $\omega\ge 1=\omega-1$.
\end{proposition}

\begin{proof}
A tree has no triangles, so $\omega(G)=2$ and every edge is a maximum clique.
For any edge $K=\{u,v\}$, the graph $G-\{uv\}$ is a forest on the same vertex
set.  A tree on $n\ge 2$ vertices has $n-1$ edges, so after deleting one edge
the resulting forest has $n-2$ edges.  If $n=2$ then $G=K_2$ and the remaining
graph has no edges, giving $\omega(G-\{uv\})=1=\omega(G)-1$, so wCDH holds
with equality.  If $n\ge 3$ then $n-2\ge 1$, so at least one edge remains and
$\omega(G-\{uv\})\ge 2>1=\omega(G)-1$.  In both cases wCDH is satisfied.
\end{proof}

