\section{Preliminaries}
\label{sec:prelim}

\begin{definition}[Notation]
Write $\omega(G)$ for the clique number of $G$.  For $K\subseteq V(G)$,
write $G-E(K)$ for the graph obtained by deleting all edges within $K$.
\end{definition}

\begin{definition}[CEP LP and dual]
The fractional CEP LP and its dual are:
\begin{align}
  &\min\;\textstyle\sum_K x_K
   \;\text{ s.t. }\;\textstyle\sum_{K\ni e}x_K=1\;\forall e,\;x_K\ge 0,
   \tag{P}\label{eq:P}\\
  &\max\;\textstyle\sum_e y_e
   \;\text{ s.t. }\;\textstyle\sum_{e\in E(K)}y_e\le 1\;\forall K,\;y_e\in\R.
   \tag{D}\label{eq:D}
\end{align}
Since \eqref{eq:P} uses equalities, $y_e$ is unrestricted in~\eqref{eq:D}.
Weak duality gives $\cp(G)\ge\operatorname{opt}(\text{D})$.
\end{definition}

%%────────────────────────────────────────────────────────────────────────────
\section{Warmup: the $n^2/4$ upper bound}
\label{sec:upper}

This bound is weaker than EOZ's $(1-c)n^2/4$ result.  We include it because
the two lemmas below are reused in the conditional theorem.

\begin{lemma}[PEO edge bound]
\label{lem:edge-bound}
If $G$ is chordal on $n$ vertices with $\omega=\omega(G)$, then
$|E(G)|\le(\omega-1)n-\binom{\omega}{2}$.
\end{lemma}

\begin{proof}
Let $v_1,\dots,v_n$ be a PEO.  Since $\Nplus(v_i)$ is a clique,
$d_i^+:=|\Nplus(v_i)|\le\omega-1$.  Also $d_i^+\le n-i$.  Summing with
$k=\omega-1$:
\[
  |E(G)|=\sum_i d_i^+\le\sum_{j=0}^{n-1}\min(k,j)
  =\tfrac{k(k+1)}{2}+(n-1-k)k=kn-\tfrac{k(k+1)}{2}
  =(\omega-1)n-\tbinom{\omega}{2}.\qquad\square
\]
\end{proof}

\begin{lemma}[Single-clique compression]
\label{lem:compress1}
For any graph $G$: $\cp(G)\le 1+|E(G)|-\binom{\omega(G)}{2}$.
\end{lemma}

\begin{proof}
Use one maximum clique $K$ (covering $\binom{\omega}{2}$ edges) and one
edge-clique per remaining edge.  No remaining edge has both endpoints in $K$
(it would already be covered), so no edge-clique conflicts with $K$.
\end{proof}

\begin{theorem}[Elementary weaker upper bound]
\label{thm:upper-n4}
For every chordal graph $G$ on $n$ vertices,
$\cp(G)\le\lfloor(n-1)^2/4\rfloor+1\le n^2/4+O(n)$.
\end{theorem}

\begin{proof}
Combining \cref{lem:edge-bound,lem:compress1}:
$\cp(G)\le 1+(\omega-1)n-2\binom{\omega}{2}=1+(\omega-1)(n-\omega)$.
Setting $x=\omega-1$, the concave quadratic $x(n-1-x)$ is maximised at
$x=(n-1)/2$ with value $\lfloor(n-1)^2/4\rfloor$.
\end{proof}

\begin{remark}
\EOZ{} prove the stronger bound $(1-c)n^2/4$ for an absolute $c>0$, using
a more refined argument.  The PEO proof above gives the weaker $n^2/4$
bound but introduces the compression technique used in \cref{sec:conditional}.
\end{remark}

